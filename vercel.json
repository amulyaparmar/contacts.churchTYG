{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm turbo run build --filter=@contacts/web",
  "outputDirectory": "apps/web/.next",
  "crons": [
    {
      "path": "/api/cron/sms-blasts",
      "schedule": "*/30 * * * *"
    }
  ]
}
